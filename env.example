# ============================================================
# jcpr-ts-v01 — Environment Variables Example (.env.example)
# ============================================================
# 사용법 (Usage):
#   1. 본 파일을 .env 로 복사 (Copy this file as .env)
#        cp .env.example .env
#   2. 로컬에서만 실제 값을 입력 (Fill in real values locally only)
#   3. .env 파일은 절대 커밋하지 않음 (NEVER commit .env)
#
# 보안 원칙 (Security principle):
# 모든 자격증명은 로컬 시스템에만 보관됩니다.
# All credentials must remain on the local system only.
# ============================================================


# ============================================================
# 운영 모드 (Operating Mode)
# ============================================================
# paper           = 종이 거래 (Paper trading)
# live_limited    = 제한 라이브 (Limited-capacity live)
# full_production = 전면 프로덕션 (Full production)
OPERATING_MODE=paper

# 세션 소유자 (Session owner — 감사 로그용)
SESSION_OWNER=JCPR


# ============================================================
# 브로커 자격증명 (Broker Credentials)
# ============================================================
# 브로커명 (Broker name) — 어댑터 선택 (Task 7-8)
# 예: alpaca, ibkr, ...
BROKER_NAME=

# API 자격증명 (API credentials)
# ⚠️ 이 값들은 절대 외부 시스템·로그·채팅에 노출되어서는 안 됨
# ⚠️ NEVER expose these values to external systems / logs / chats
BROKER_API_KEY=
BROKER_API_SECRET=

# API 엔드포인트 (Endpoint)
# paper 와 live 가 다른 URL 인 경우가 많음
# Paper and live often have different URLs
BROKER_BASE_URL=

# 브로커 계좌 ID (Broker account identifier)
BROKER_ACCOUNT_ID=

# 추가 인증 (Additional auth — 필요 시)
# BROKER_OAUTH_TOKEN=
# BROKER_REFRESH_TOKEN=


# ============================================================
# 시장 데이터 (Market Data — 별도 제공자 사용 시)
# ============================================================
# 브로커가 시세를 제공하면 비워둠
# Leave empty if broker provides quotes
MARKET_DATA_PROVIDER=
MARKET_DATA_API_KEY=


# ============================================================
# 데이터베이스 (Database)
# ============================================================
# 로컬 SQLite 경로 (Local SQLite path) — 기본값 권장
DB_PATH=./data/jcpr.sqlite

# PostgreSQL 사용 시 (If using PostgreSQL)
# DB_URL=postgresql://user:password@localhost:5432/jcpr


# ============================================================
# 로깅 (Logging)
# ============================================================
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR
LOG_DIR=./logs
LOG_MASK_SECRETS=true       # 시크릿 자동 마스킹 (auto-mask secrets)


# ============================================================
# 비상 정지 (Emergency Stop)
# ============================================================
# 킬 스위치 파일 경로 — 이 파일이 존재하면 신규 주문 영구 차단
# Kill switch file path — when present, new orders are permanently blocked
KILL_SWITCH_PATH=./runtime/KILL_SWITCH_ON


# ============================================================
# 보고서 (Reports)
# ============================================================
REPORT_DIR=./reports/output
REPORT_FORMAT=html          # html | pdf | json


# ============================================================
# 설정 파일 경로 (Config File Paths)
# ============================================================
# 모드별로 다른 설정 파일 사용
# Different config per operating mode
CAPACITY_CONFIG=./configs/capacity.local.yaml
RISK_LIMITS_CONFIG=./configs/risk_limits.local.yaml
LIVE_LIMITED_CONFIG=./configs/live_limited.yaml


# ============================================================
# MCP 서버 (MCP Servers — Task 34-35, 선택)
# ============================================================
# MCP_READONLY_PORT=8765
# MCP_RESTRICTED_PORT=8766


# ============================================================
# LLM / 에이전트 (LLM / Agents — Task 36-39, 선택)
# ============================================================
# 에이전트 기능 사용 시에만 설정
# Required only if using agent features
# ANTHROPIC_API_KEY=


# ============================================================
# 알림 (Notifications — 선택)
# ============================================================
# 비상 정지·예외 발생 시 알림 채널 (선택)
# Notification channels for emergency stops / exceptions (optional)
# NOTIFY_EMAIL=
# NOTIFY_WEBHOOK_URL=


# ============================================================
# 종료 (End of file)
# ============================================================
# 마지막 점검 (Final check):
#   - 본 파일(.env.example)에는 실제 값이 없어야 합니다.
#   - This file (.env.example) must contain NO real values.
# ============================================================
