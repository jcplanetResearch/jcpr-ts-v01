# ============================================================
# jcpr-ts-v01 — Environment Variables Example
# ============================================================
# 사용법: 본 파일을 .env 로 복사 후 실제 값을 입력
# Copy this file as .env and fill in real values locally only.
# 절대 .env 를 커밋하지 마십시오. (NEVER commit .env)
# ============================================================

# --- 브로커 자격증명 (Broker Credentials) ---
BROKER_NAME=                  # e.g. alpaca, ibkr, ...
BROKER_API_KEY=
BROKER_API_SECRET=
BROKER_BASE_URL=              # paper or live endpoint
BROKER_ACCOUNT_ID=

# --- 운영 모드 (Operating Mode) ---
OPERATING_MODE=paper          # paper | live_limited | full_production
SESSION_OWNER=JCPR

# --- 데이터베이스 (Database) ---
DB_PATH=./data/jcpr.sqlite

# --- 로깅 (Logging) ---
LOG_LEVEL=INFO
LOG_DIR=./logs

# --- 비상 정지 (Emergency Stop) ---
KILL_SWITCH_PATH=./runtime/KILL_SWITCH_ON

# --- 보고서 (Reports) ---
REPORT_DIR=./reports/output
