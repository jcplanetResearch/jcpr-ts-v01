# =============================================================================
# JCPR Trading System — .gitignore
# =============================================================================
# CRITICAL: .env must NEVER be committed.
# =============================================================================

# Secrets — NEVER COMMIT
.env
.env.local
.env.*.local
gitignore
*.key
*.pem
*.p12
credentials.json
secrets.yaml
secrets.yml

# Token caches (contain access tokens)
runtime/
.kis_token_*.json

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# IDE
.idea/
.vscode/
*.swp
*.swo

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Audit / data (contains PII — do not commit)
data/
logs/
audit/

# Backup folders created by sync scripts
.backup_task*/
.venv/

data/approvals.sqlite*
